
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow reading options
    match /options/{document} {
      allow read: if request.auth != null;
      allow write: if true; // Allow for testing
    }

    // Allow reading ingredients
    match /ingredients/{document} {
      allow read: if request.auth != null;
      allow write: if true; //Allow for testing
    }
    
    match /{document=**} {
      allow read, write: if false;
    }

    //allow AI usage tracking
    match /chatbot_usage/{userId} {
      //users only read/write their own usage
      allow read, write: if request.auth != null && request.auth.uid == userId;

      //validate on create
      allow create: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['date', 'count', 'userId'])
        && request.resource.data.count is number
        && request.resource.data.count >= 0;
      
      // Validate on update
      allow update: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.data.count is number
        && request.resource.data.count >= 0
        && request.resource.data.count <= 1000;
    }
  }
}